# Copy this file to `secrets.yaml` and fill in real values.
# `secrets.yaml` is gitignored — NEVER commit real credentials.

wifi_ssid: "YourWiFiNetwork"
wifi_password: "your-wifi-password"

# Password for the fallback setup hotspot.
ap_password: "change-me-ap"

# Password protecting OTA (over-the-air) firmware updates.
ota_password: "change-me-ota"
